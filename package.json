{
  "name": "@opensyria/datasets-api",
  "version": "0.2.0",
  "description": "Read-only datasets API for OpenSyria.",
  "author": "OpenSyria",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "pnpm run db:generate && nest build && node -e \"const fs=require('node:fs'); if (!fs.existsSync('dist/main.js')) { console.error('Missing dist/main.js'); process.exit(1); }\"",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration:db": "pnpm run db:migrate:deploy && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-integration.json --runInBand",
    "datasets:sync": "pnpm run build && node dist/cli/sync-dataset-releases.js",
    "datasets:sync:prod": "node dist/cli/sync-dataset-releases.js",
    "read-model:import:geography": "pnpm run build && node dist/cli/import-geography-read-model.js",
    "read-model:import:geography:prod": "node dist/cli/import-geography-read-model.js",
    "read-model:refresh:geography": "pnpm run datasets:sync && pnpm run read-model:import:geography",
    "read-model:refresh:geography:prod": "pnpm run datasets:sync:prod && pnpm run read-model:import:geography:prod",
    "smoke:geography": "ts-node -r tsconfig-paths/register src/cli/smoke-geography-release.ts",
    "smoke:transport": "ts-node -r tsconfig-paths/register src/cli/smoke-transport-release.ts",
    "smoke:transport:prod": "node dist/cli/smoke-transport-release.js",
    "audit:prod": "pnpm audit --prod",
    "release:check": "node scripts/check-release.js",
    "release:check:public-api-bridge": "node scripts/check-public-api-bridge.js",
    "release:check:docker": "node scripts/check-release.js --docker-build",
    "validate": "pnpm run db:generate && pnpm run check && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run test:e2e && pnpm run build && pnpm run audit:prod",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.1.3",
    "@keyv/redis": "^5.1.6",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/nestjs-api-reference": "^1.2.8",
    "cache-manager": "^7.2.9",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "ioredis": "^5.11.1",
    "keyv": "^5.6.0",
    "nestjs-graceful-shutdown": "^2.0.0",
    "nestjs-i18n": "^10.8.4",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "pg": "^8.22.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^17.0.8",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
